# Jira Cloud service account configuration
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=agent-service-account@example.com
ATLASSIAN_API_TOKEN=replace-with-real-api-token

# Optional: default JQL used by the operator console
ATLASSIAN_JIRA_POLL_JQL=assignee = currentUser() AND statusCategory != Done ORDER BY updated DESC

# Optional: Confluence live integration for search/read/publish
ATLASSIAN_CONFLUENCE_BASE_URL=https://your-wiki-domain.atlassian.net
ATLASSIAN_CONFLUENCE_SPACE=replace-with-confluence-space-id
ATLASSIAN_CONFLUENCE_PARENT_PAGE_ID=replace-with-parent-page-id
ATLASSIAN_CONFLUENCE_PUBLISH_MODE=manual

# Optional: operator-triggered Outlook SMTP delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace-with-real-smtp-password
SMTP_FROM_ADDRESS=agent-service-account@example.com
SMTP_FROM_NAME=Common Employee
SMTP_USE_STARTTLS=true

# Optional: Teams progress self-alerting
TEAMS_PROGRESS_WEBHOOK_URL=https://example.webhook.office.com/replace-me
