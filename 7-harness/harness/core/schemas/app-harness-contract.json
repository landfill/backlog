{
  "app_discovery": {
    "required_path": "docs/PLANS.md"
  },
  "required_files": [
    "AGENTS.md",
    "ARCHITECTURE.md",
    "docs/PLANS.md",
    "docs/SECURITY.md",
    "docs/RELIABILITY.md",
    "docs/status/README.md",
    "docs/status/tracker.md",
    "docs/status/ongoing/README.md",
    "docs/status/completed/README.md"
  ],
  "required_role_mapping_patterns": [
    {
      "role": "PM",
      "pattern": "repository-level `PM`"
    },
    {
      "role": "Coder",
      "pattern": "repository-level `Coder`"
    },
    {
      "role": "Security Reviewer",
      "pattern": "repository-level `Security Reviewer`"
    },
    {
      "role": "Tester",
      "pattern": "repository-level[^\\n]*`Tester`"
    }
  ],
  "tracker": {
    "required_sections": [
      "## Current Phase",
      "## Current Step",
      "## Current Work",
      "## Verification",
      "## Operating State",
      "## Next Owner",
      "## Next Action"
    ],
    "required_fields": [
      "phase",
      "status",
      "owner",
      "state",
      "title",
      "path",
      "verdict",
      "attempts",
      "evidence",
      "checkpoint_ref",
      "cleanup_status",
      "next"
    ],
    "allowed_verdicts": [
      "APPROVED",
      "CHANGES_REQUESTED",
      "BLOCKED",
      "SKIPPED"
    ],
    "allowed_cleanup_statuses": [
      "CLEAN",
      "REMAINING_OK",
      "BLOCKED"
    ]
  },
  "task_brief": {
    "glob": "docs/status/ongoing/*task-brief.md",
    "required_sections": [
      "Goal",
      "Primary Output",
      "In Scope",
      "Out of Scope",
      "Done When",
      "Verification Plan"
    ],
    "optional_sections": [
      "Inputs",
      "Expected Output",
      "Risk Notes"
    ]
  },
  "ongoing_plan": {
    "glob": "docs/status/ongoing/*ongoing-plan.md",
    "required_sections": [
      "Goal",
      "Scope",
      "Current Owner",
      "Current Step",
      "Current State",
      "Operating State",
      "Verification",
      "Verification Evidence",
      "Failure Record",
      "Next Owner",
      "Next Step",
      "Issues"
    ],
    "allowed_verdicts": [
      "APPROVED",
      "CHANGES_REQUESTED",
      "BLOCKED",
      "SKIPPED"
    ],
    "allowed_cleanup_statuses": [
      "CLEAN",
      "REMAINING_OK",
      "BLOCKED"
    ]
  },
  "review_report": {
    "globs": [
      "docs/status/ongoing/*review-report*.md",
      "docs/status/completed/*review-report*.md"
    ],
    "required_sections": [
      "Verdict",
      "Reason",
      "Scope",
      "Checked",
      "Passed",
      "Evidence",
      "Checkpoint",
      "Cleanup",
      "Open Risks",
      "Next Owner",
      "Next Step"
    ],
    "allowed_verdicts": [
      "APPROVED",
      "CHANGES_REQUESTED",
      "BLOCKED",
      "SKIPPED"
    ],
    "allowed_cleanup_statuses": [
      "CLEAN",
      "REMAINING_OK",
      "BLOCKED"
    ]
  },
  "active_work": {
    "active_dir": "docs/status/ongoing",
    "task_brief_suffix": "-task-brief.md",
    "ongoing_plan_pattern": "{slug}-ongoing-plan*.md",
    "review_report_pattern": "{slug}-review-report*.md"
  }
}
